# ============================================================
# release-note-server — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------------
# OpenRouter (required for AI-powered release notes)
# Get your key at https://openrouter.ai/keys
# ------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...

# Default model used by /api/release-notes/ai and --ai CLI flag.
# Any model available on OpenRouter works here, e.g.:
#   openai/gpt-4o-mini          (fast & cheap, default)
#   openai/gpt-4o
#   anthropic/claude-3.5-sonnet
#   google/gemini-2.0-flash
#   meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=openai/gpt-4o-mini

# OpenRouter API base URL — only change this if you use a compatible
# self-hosted proxy.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ------------------------------------------------------------------
# HTTP Server
# ------------------------------------------------------------------
PORT=3000
HOST=0.0.0.0
